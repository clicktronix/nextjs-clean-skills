{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/clicktronix/nextjs-clean-skills/schemas/codex-plugin-manifest.schema.json",
  "title": "Codex plugin manifest",
  "description": "Schema for plugins/nextjs-clean-skills/.codex-plugin/plugin.json",
  "type": "object",
  "required": ["name", "version", "description", "license", "keywords", "skills", "interface"],
  "properties": {
    "name": { "const": "nextjs-clean-skills" },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "description": { "type": "string", "minLength": 1 },
    "license": { "type": "string", "minLength": 1 },
    "homepage": { "type": "string", "format": "uri" },
    "repository": { "type": "string", "format": "uri" },
    "author": {
      "type": "object",
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" }
      },
      "required": ["name"]
    },
    "keywords": {
      "type": "array",
      "minItems": 15,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "skills": { "const": "./skills/" },
    "interface": {
      "type": "object",
      "required": ["displayName", "shortDescription", "longDescription", "defaultPrompt"],
      "properties": {
        "displayName": { "type": "string", "minLength": 1 },
        "shortDescription": { "type": "string", "minLength": 1 },
        "longDescription": { "type": "string", "minLength": 1 },
        "developerName": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 },
        "capabilities": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "websiteURL": { "type": "string", "format": "uri" },
        "defaultPrompt": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "additionalProperties": true
}
