{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/clicktronix/nextjs-clean-skills/schemas/claude-marketplace.schema.json",
  "title": "Claude Code marketplace manifest",
  "description": "Schema for .claude-plugin/marketplace.json",
  "type": "object",
  "required": ["name", "metadata", "plugins"],
  "properties": {
    "name": { "const": "nextjs-clean-skills" },
    "owner": {
      "type": "object",
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" }
      },
      "required": ["name"]
    },
    "metadata": {
      "type": "object",
      "required": ["version"],
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" }
      }
    },
    "plugins": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "source", "version", "keywords"],
        "properties": {
          "name": { "const": "nextjs-clean-skills" },
          "source": { "const": "./plugins/nextjs-clean-skills" },
          "description": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
          "keywords": {
            "type": "array",
            "minItems": 15,
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          }
        }
      }
    }
  },
  "additionalProperties": true
}
